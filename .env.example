PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# Comma-separated allowed origins. Use explicit domains; do not use *.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# API docs exposure toggles. Keep false in production unless explicitly required.
ENABLE_API_DOCS=true
EXPOSE_OPENAPI_JSON=true

# MongoDB connection URI
DATABASE_URL=mongodb://localhost:27017/doc-gen-service

# Strong random secret (>=32 chars required in production)
JWT_SECRET=replace-with-strong-random-secret
