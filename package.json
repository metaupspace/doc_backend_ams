{
  "name": "document-generation-service",
  "version": "1.0.0",
  "description": "Production-ready document generation service with JWT token validation and PDF streaming",
  "type": "module",
  "main": "dist/server.ts",
  "scripts": {
    "build": "npm run typecheck && tsup",
    "start": "node dist/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "document-generation",
    "pdf",
    "express",
    "mongodb",
    "jwt"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "ipaddr.js": "^1.9.1",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^5.7.0",
    "mongoose": "^7.4.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.13.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^8.45.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
